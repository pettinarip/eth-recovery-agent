# Sentry API token — create one at:
#   https://sentry.io/settings/account/api/auth-tokens/
#   Scopes needed: project:read, event:read
SENTRY_AUTH_TOKEN=

# Netlify personal access token — create one at:
#   https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_AUTH_TOKEN=

# Netlify site ID — found in Site configuration > General > Site ID
NETLIFY_SITE_ID=
