# Sentry API token — create one at:
#   https://sentry.io/settings/account/api/auth-tokens/
#   Scopes needed: project:read, event:read
SENTRY_AUTH_TOKEN=

# Grafana service account token
# Ask devops for access to the managed Grafana instance
GRAFANA_URL=
GRAFANA_TOKEN=
# VictoriaMetrics Logs datasource UID
GRAFANA_DATASOURCE_UID=
# Grafana organization ID
GRAFANA_ORG_ID=

# Discord webhook URL for PR/issue notifications
# Create one at: Discord channel settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Trigger.dev — data layer task monitoring
# Secret API key from project settings (prefixed tr_prod_ for production)
TRIGGER_DEV_API_KEY=
# Project ref (starts with proj_)
TRIGGER_DEV_PROJECT_REF=proj_jnkvoplayqkrsnovqsdr
